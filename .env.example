# Telephony
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# STT
DEEPGRAM_API_KEY=your_deepgram_api_key

# LLM
ANTHROPIC_API_KEY=your_anthropic_api_key

# TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID_EN=your_english_voice_id
ELEVENLABS_VOICE_ID_HI=your_hindi_voice_id
ELEVENLABS_VOICE_ID_TA=your_tamil_voice_id

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voice_agent

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
WEBSOCKET_PORT=3001
BASE_URL=https://your-ngrok-or-domain.com

# Logging
LOG_LEVEL=debug
